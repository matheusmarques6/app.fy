# Server
NODE_ENV=production
PORT=3000

# Database (Neon with pooling)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require&pgbouncer=true
# Direct connection for migrations (no pooler)
DIRECT_DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Redis (BullMQ)
REDIS_HOST=redis.railway.internal
REDIS_PORT=6379

# JWT Secrets
JWT_SECRET=your-jwt-secret-here-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-here-min-32-chars

# Console URL (for CORS)
CONSOLE_BASE_URL=https://console.appfy.com

# OneSignal (per store, stored in DB - these are defaults/fallback)
# ONESIGNAL_APP_ID=
# ONESIGNAL_REST_API_KEY=

# Workers Concurrency
BULL_CONCURRENCY_EVENTS=10
BULL_CONCURRENCY_METRICS=5
BULL_CONCURRENCY_SEGMENT=5
BULL_CONCURRENCY_AUTOMATION=5
BULL_CONCURRENCY_PUSH=20
BULL_CONCURRENCY_CAMPAIGN=10

# Storage (R2/S3)
STORAGE_ENDPOINT=https://xxx.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_BUCKET=appfy-assets

# Optional: Sentry
# SENTRY_DSN=
