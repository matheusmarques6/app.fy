# Server
NODE_ENV=production
PORT=3000

# Database (Neon with pooling)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require&pgbouncer=true
# Direct connection for migrations (no pooler)
DIRECT_DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Redis (BullMQ)
REDIS_HOST=redis.railway.internal
REDIS_PORT=6379

# JWT Secrets
JWT_SECRET=your-jwt-secret-here-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-here-min-32-chars

# Console URL (for CORS)
CONSOLE_BASE_URL=https://console.appfy.com

# OneSignal (per store, stored in DB - these are defaults/fallback)
# ONESIGNAL_APP_ID=
# ONESIGNAL_REST_API_KEY=

# Workers Concurrency
BULL_CONCURRENCY_EVENTS=10
BULL_CONCURRENCY_METRICS=5
BULL_CONCURRENCY_SEGMENT=5
BULL_CONCURRENCY_AUTOMATION=5
BULL_CONCURRENCY_PUSH=20
BULL_CONCURRENCY_CAMPAIGN=10

# Storage (R2/S3)
S3_ENDPOINT=https://xxx.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=appfy-assets
S3_REGION=auto
# S3_PUBLIC_URL=https://cdn.appfy.com (optional, for public asset URLs)

# Credentials Encryption (AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIALS_ENCRYPTION_KEY=

# Codemagic (App Builds)
CODEMAGIC_API_TOKEN=your-codemagic-api-token
CODEMAGIC_APP_ID=your-codemagic-app-id
CODEMAGIC_WEBHOOK_SECRET=your-webhook-secret-min-32-chars
CODEMAGIC_BRANCH=main
CODEMAGIC_FLUTTER_VERSION=stable

# API Base URL (for webhooks callback)
API_BASE_URL=https://api.appfy.com

# Optional: Sentry
# SENTRY_DSN=
