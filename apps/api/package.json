{
  "name": "@appfy/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@appfy/core": "workspace:*",
    "@appfy/db": "workspace:*",
    "@appfy/integrations": "workspace:*",
    "@appfy/shared": "workspace:*",
    "@hono/node-server": "^1.14.3",
    "bullmq": "^5.71.0",
    "hono": "^4.7.13",
    "jose": "^6.0.13",
    "stripe": "^17.7.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@appfy/test-utils": "workspace:*",
    "@types/node": "^22.16.4",
    "tsx": "^4.19.4"
  }
}
