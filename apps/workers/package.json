{
  "name": "@appfy/workers",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:push": "tsx watch src/push/index.ts",
    "dev:ingestion": "tsx watch src/ingestion/index.ts",
    "dev:analytics": "tsx watch src/analytics/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start:push": "node dist/push/index.js",
    "start:ingestion": "node dist/ingestion/index.js",
    "start:analytics": "node dist/analytics/index.js",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@appfy/core": "workspace:*",
    "@appfy/db": "workspace:*",
    "@appfy/integrations": "workspace:*",
    "@appfy/shared": "workspace:*",
    "bullmq": "^5.52.4",
    "ioredis": "^5.6.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^22.16.4",
    "tsx": "^4.19.4"
  }
}
