{
  "name": "appfy",
  "version": "0.1.0",
  "private": true,
  "description": "SaaS E-commerce App Builder - Transform stores into mobile apps",
  "pnpm": {
    "overrides": {
      "glob": ">=10.5.0",
      "tar": ">=7.5.4",
      "lodash": ">=4.17.23",
      "tmp": ">=0.2.4"
    }
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "pnpm --filter @appfy/shared build && pnpm --filter @appfy/api db:generate && pnpm --filter @appfy/api build",
    "start": "cd apps/api && pnpm db:migrate:prod && node dist/main.js",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "db:generate": "pnpm --filter @appfy/api db:generate",
    "db:push": "pnpm --filter @appfy/api db:push",
    "db:migrate": "pnpm --filter @appfy/api db:migrate",
    "db:studio": "pnpm --filter @appfy/api db:studio",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.3.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
