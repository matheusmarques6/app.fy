# AppFy Environment Variables
# Copy to .env and fill in values

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL="postgresql://appfy:appfy_dev_password@localhost:5432/appfy?schema=public"
# For pooled connections (production with Neon)
# DATABASE_URL="postgresql://user:pass@host/db?pgbouncer=true"
# DIRECT_URL="postgresql://user:pass@host/db"

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL="redis://localhost:6379"

# =============================================================================
# JWT / AUTH
# =============================================================================
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_ISSUER="appfy-auth"
JWT_AUDIENCE_DEVICE="appfy-device"
JWT_AUDIENCE_USER="appfy-console"

# Ed25519 keys for Remote Config signing (generate with openssl)
# openssl genpkey -algorithm ed25519 -out rc_private.pem
# openssl pkey -in rc_private.pem -pubout -out rc_public.pem
RC_SIGNING_PRIVATE_KEY=""
RC_SIGNING_PUBLIC_KEY=""
RC_SIGNING_KEY_ID="rc_key_2026_01"

# =============================================================================
# ONESIGNAL
# =============================================================================
ONESIGNAL_APP_ID=""
ONESIGNAL_API_KEY=""

# =============================================================================
# INTEGRATIONS
# =============================================================================
# Shopify
SHOPIFY_CLIENT_ID=""
SHOPIFY_CLIENT_SECRET=""

# WooCommerce (per-store, but these are defaults for dev)
WOOCOMMERCE_CONSUMER_KEY=""
WOOCOMMERCE_CONSUMER_SECRET=""

# =============================================================================
# STORAGE (S3/R2/MinIO)
# =============================================================================
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="appfy_minio"
S3_SECRET_ACCESS_KEY="appfy_minio_secret"
S3_BUCKET_ASSETS="appfy-assets"
S3_BUCKET_LOGS="appfy-logs"

# =============================================================================
# OBSERVABILITY
# =============================================================================
SENTRY_DSN=""
OTEL_EXPORTER_OTLP_ENDPOINT=""
LOG_LEVEL="debug"

# =============================================================================
# APP CONFIG
# =============================================================================
NODE_ENV="development"
PORT=3000
WORKERS_PORT=3001
API_BASE_URL="http://localhost:3000"
CONSOLE_BASE_URL="http://localhost:3100"

# =============================================================================
# GITHUB ACTIONS (for build/publish orchestration)
# =============================================================================
GITHUB_TOKEN=""
GITHUB_REPO_OWNER=""
GITHUB_REPO_NAME=""

# =============================================================================
# APPLE / GOOGLE (for app publishing)
# These are stored per-store in encrypted secrets, not here
# =============================================================================
# APPLE_TEAM_ID=""
# APPLE_KEY_ID=""
# APPLE_ISSUER_ID=""
# GOOGLE_SERVICE_ACCOUNT_JSON=""
