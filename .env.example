# AppFy Environment Variables
# Copy to .env and fill in values

# =============================================================================
# DATABASE — Supabase PostgreSQL
# =============================================================================
# Pooled connection (via pgBouncer) — use for runtime/API
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection — use for migrations (prisma migrate deploy)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# Local dev fallback (Docker)
# DATABASE_URL="postgresql://appfy:appfy_dev_password@localhost:5432/appfy?schema=public"
# DIRECT_URL="postgresql://appfy:appfy_dev_password@localhost:5432/appfy?schema=public"

# =============================================================================
# SUPABASE
# =============================================================================
SUPABASE_URL="https://[project-ref].supabase.co"
SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
# Used by the API to validate Supabase JWTs from the console
SUPABASE_JWT_SECRET="your-supabase-jwt-secret"

# Console (Next.js public vars)
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# =============================================================================
# REDIS — Upstash (production) or local (development)
# =============================================================================
# Upstash (production): rediss://default:[password]@[host].upstash.io:6379
# Local Docker: redis://localhost:6379
REDIS_URL="redis://localhost:6379"

# =============================================================================
# JWT / AUTH — Device tokens (mobile app only)
# Console auth is handled by Supabase Auth
# =============================================================================
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_ISSUER="appfy-auth"
JWT_AUDIENCE_DEVICE="appfy-device"
JWT_AUDIENCE_USER="appfy-console"

# Ed25519 keys for Remote Config signing (generate with openssl)
# openssl genpkey -algorithm ed25519 -out rc_private.pem
# openssl pkey -in rc_private.pem -pubout -out rc_public.pem
RC_SIGNING_PRIVATE_KEY=""
RC_SIGNING_PUBLIC_KEY=""
RC_SIGNING_KEY_ID="rc_key_2026_01"

# =============================================================================
# ONESIGNAL
# =============================================================================
ONESIGNAL_APP_ID=""
ONESIGNAL_API_KEY=""

# =============================================================================
# ENCRYPTION & SECURITY
# =============================================================================
# Used to derive the AES-256-GCM encryption key for credentials (API keys, tokens)
ENCRYPTION_SECRET="your-32-char-min-encryption-secret"
ENCRYPTION_SALT="appfy-enc-v1"
# Used to hash emails for privacy-preserving lookups
EMAIL_HASH_SALT="your-email-hash-salt-change-in-production"

# =============================================================================
# WEBHOOKS
# =============================================================================
# Public base URL of the API — used to register webhook delivery URLs
WEBHOOK_BASE_URL="https://api.yourapp.com"

# =============================================================================
# INTEGRATIONS
# =============================================================================
# Shopify
SHOPIFY_CLIENT_ID=""
SHOPIFY_CLIENT_SECRET=""

# WooCommerce (per-store, but these are defaults for dev)
WOOCOMMERCE_CONSUMER_KEY=""
WOOCOMMERCE_CONSUMER_SECRET=""

# =============================================================================
# STORAGE — Supabase Storage
# =============================================================================
# Supabase Storage buckets (create manually in Supabase Dashboard)
# Bucket: appfy-assets (public), appfy-logs (private)
SUPABASE_STORAGE_BUCKET_ASSETS="appfy-assets"
SUPABASE_STORAGE_BUCKET_LOGS="appfy-logs"

# Legacy S3/MinIO (kept for reference / local dev)
# S3_ENDPOINT="http://localhost:9000"
# S3_REGION="us-east-1"
# S3_ACCESS_KEY_ID="appfy_minio"
# S3_SECRET_ACCESS_KEY="appfy_minio_secret"
# S3_BUCKET_ASSETS="appfy-assets"
# S3_BUCKET_LOGS="appfy-logs"

# =============================================================================
# CODEMAGIC (for app builds)
# =============================================================================
CODEMAGIC_API_TOKEN=""
CODEMAGIC_APP_ID=""

# =============================================================================
# OBSERVABILITY
# =============================================================================
SENTRY_DSN=""
LOG_LEVEL="debug"

# =============================================================================
# APP CONFIG
# =============================================================================
NODE_ENV="development"
PORT=3000
WORKERS_PORT=3001
API_BASE_URL="http://localhost:3000"
CONSOLE_BASE_URL="http://localhost:3100"
NEXT_PUBLIC_API_URL="http://localhost:3000/v1"

# =============================================================================
# GITHUB ACTIONS (for build/publish orchestration)
# =============================================================================
GITHUB_TOKEN=""
GITHUB_REPO_OWNER=""
GITHUB_REPO_NAME=""
